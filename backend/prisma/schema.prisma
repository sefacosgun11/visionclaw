generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evidence {
  id          String   @id @default(cuid())
  type        String
  taskId      String?
  procedureId String?
  stepNumber  Int?
  timestamp   DateTime @default(now())
  capturedBy  String
  url         String?
  localPath   String?
  description String?
  tags        String[]
  metadata    Json?

  analysis Analysis?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analysis {
  id         String   @id @default(cuid())
  evidenceId String   @unique
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  status            String
  analyzedAt        DateTime?
  processingTimeMs  Int?
  confidence        Float?
  findings          Json
  proceduralContext Json?
  qualityAssessment Json?
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Equipment {
  id                  String    @id @default(cuid())
  name                String
  type                String // "pump", "valve", "motor", "compressor", etc.
  model               String?
  serialNumber        String?   @unique
  manufacturer        String?
  location            String
  status              String    @default("operational") // operational, maintenance, offline
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  specifications      Json?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tasks       Task[]
  inspections Inspection[]
}

model Procedure {
  id             String   @id @default(cuid())
  title          String
  description    String
  category       String // "maintenance", "safety", "operation", "emergency"
  steps          Json // [{stepNumber, title, description, estimatedTime, requiredTools, safetyNotes}]
  equipmentTypes String[] // ["pump", "valve", etc.]
  version        String   @default("1.0")
  status         String   @default("active") // draft, active, archived
  createdBy      String
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks       Task[]
  inspections Inspection[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String // "maintenance", "inspection", "repair", "installation"
  assignedTo  String
  priority    String    @default("medium") // low, medium, high, critical
  status      String    @default("pending") // pending, in-progress, completed, cancelled
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  equipmentId String?
  procedureId String?
  evidenceIds String[] // Array of evidence IDs
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  equipment Equipment? @relation(fields: [equipmentId], references: [id])
  procedure Procedure? @relation(fields: [procedureId], references: [id])
}

model Inspection {
  id                 String    @id @default(cuid())
  type               String // "routine", "emergency", "compliance"
  equipmentId        String
  procedureId        String?
  inspector          String
  date               DateTime
  status             String    @default("scheduled") // scheduled, in-progress, completed
  findings           Json // [{severity, description, correctiveAction}]
  overallStatus      String? // "pass", "fail", "needs-attention"
  evidenceIds        String[] // Array of evidence IDs
  nextInspectionDate DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  equipment        Equipment         @relation(fields: [equipmentId], references: [id])
  procedure        Procedure?        @relation(fields: [procedureId], references: [id])
  moduleExecutions ModuleExecution[]
}

model InspectionModule {
  id          String  @id // "presence-check", "defect-detection"
  name        String // "Presence/Missing Item Detection"
  description String
  category    String // "vision", "measurement", "analysis", "safety"
  version     String  @default("1.0.0")
  author      String? // "VisionClaw" veya müşteri adı

  // Modül durumu
  status    String  @default("active") // active, deprecated, beta
  isPublic  Boolean @default(true) // Marketplace'de görünsün mü?
  isPremium Boolean @default(false) // Ücretli modül mü?

  // Konfigürasyon
  configSchema Json // JSON Schema for module config

  // UI Components (paths)
  configComponent String? // React component path for config form
  resultComponent String? // React component path for result display

  // Metadata
  icon  String? // Icon name or emoji
  color String? // Primary color for UI
  tags  String[] // ["safety", "checklist", "vision"]

  // Stats
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  // Relations
  executions ModuleExecution[]
  templates  ModuleTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModuleTemplate {
  id          String  @id @default(cuid())
  moduleId    String
  name        String // "Kaynak İstasyonu - Güvenlik"
  description String?
  category    String? // "safety", "assembly", "quality"

  // Template configuration
  config Json // Modül-specific config

  // Reference data
  referenceImageUrl   String? // Optional reference image
  referenceEvidenceId String?

  // Access control
  isPublic       Boolean @default(true)
  createdBy      String
  organizationId String? // Müşteri ID'si

  // Stats
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  // Relations
  module     InspectionModule  @relation(fields: [moduleId], references: [id])
  executions ModuleExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModuleExecution {
  id         String  @id @default(cuid())
  moduleId   String
  templateId String?
  evidenceId String

  // Execution details
  config Json // Config used for this execution
  status String // "success", "failed", "needs-review", "error"

  // Results
  result           Json // Module-specific result format
  confidence       Float?
  processingTimeMs Int?

  // Context
  inspectionId String? // Link to Inspection record
  executedBy   String

  // Relations
  module     InspectionModule @relation(fields: [moduleId], references: [id])
  template   ModuleTemplate?  @relation(fields: [templateId], references: [id])
  inspection Inspection?      @relation(fields: [inspectionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
